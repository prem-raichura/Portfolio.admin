generator client {
  provider = "prisma-client-js"
  engineType = "binary"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id Int @id @default(autoincrement())

  name String @db.VarChar(255)

  username String? @unique @db.VarChar(100)

  email String @unique @db.VarChar(255)

  github_id String? @unique @db.VarChar(100)

  password String? @db.VarChar(255)

  avatar String? @db.VarChar(500)

  bio String?

  users_links Json?
  skills Json?

  headline      String?  @db.VarChar(255)


  is_public Boolean @default(true)
  is_active Boolean @default(true)

  created_at DateTime @default(now())
  last_login DateTime?
  updated_at DateTime @updatedAt

  api_keys API[]
  projects Projects[]
  certificates Certificates[]
  experiences Experience[]
  contacts Contact[]
  dashboard Dashboard?
  logs Logs[]
  refresh_tokens RefreshToken[]
  dashboard_analytics DashboardAnalytics[]
  visitor_sessions VisitorSession[]
}


model API {
  id Int @id @default(autoincrement())

  user_id Int

  name String @db.VarChar(255)
  api_key String @db.VarChar(255)

  rate_limit Int @default(1000)

  last_used_at DateTime?
  expires_at DateTime?

  status String @default("active")

  created_at DateTime @default(now())

  deleted_at DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, deleted_at])
}

model Projects {
  id Int @id @default(autoincrement())

  user_id Int

  title String @db.VarChar(255)
  slug String? @db.VarChar(255)

  authors_contributors Json?

  description String?

  publisher String? @db.VarChar(255)
  status String? @db.VarChar(255)

  tags Json?
  links Json?

  thumbnail String? @db.VarChar(500)

  featured Boolean @default(false)

  type String @db.VarChar(255)

  date_time DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  deleted_at DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Uniqueness on (user_id, slug) is enforced by a partial unique index
  // (WHERE deleted_at IS NULL) declared in the soft-delete migration.
  // Do not re-add `@@unique([user_id, slug])` here.
  @@index([user_id])
  @@index([user_id, deleted_at])
}

model Certificates {
  id Int @id @default(autoincrement())

  user_id Int

  title String @db.VarChar(255)

  slug String @db.VarChar(255)

  type String @db.VarChar(100)

  link String? @db.VarChar(500)

  images Json?

  archive_status String? @db.VarChar(255)

  issued_by String? @db.VarChar(255)

  issue_date DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  deleted_at DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Uniqueness on (user_id, slug) is enforced by a partial unique index
  // (WHERE deleted_at IS NULL) declared in the soft-delete migration.
  @@index([user_id])
  @@index([user_id, deleted_at])
}

model Experience {
  id Int @id @default(autoincrement())

  user_id Int

  title String @db.VarChar(255)

  slug String @db.VarChar(255)

  description String?

  start_date DateTime
  end_date DateTime?

  is_current Boolean @default(false)

  links Json?

  images Json?

  company String @db.VarChar(255)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  location String? @db.VarChar(255)
  mode String? @db.VarChar(255)

  deleted_at DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Uniqueness on (user_id, slug) is enforced by a partial unique index
  // (WHERE deleted_at IS NULL) declared in the soft-delete migration.
  @@index([user_id])
  @@index([user_id, deleted_at])
}

model Contact {
  id Int @id @default(autoincrement())

  user_id Int

  email String @db.VarChar(255)
  name String @db.VarChar(255)

  subject String? @db.VarChar(255)

  message String

  is_read Boolean @default(false)

  created_at DateTime @default(now())

  deleted_at DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, deleted_at])
}

model Dashboard {
  id Int @id @default(autoincrement())

  user_id Int @unique

  total_visit Int @default(0)
  unique_visitor Int @default(0)

  github_clicks Int @default(0)
  live_demo_clicks Int @default(0)

  resume_download Int @default(0)

  project_clicks Int @default(0)
  contact_submissions Int @default(0)

  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Logs {
  id Int @id @default(autoincrement())

  user_id Int?
  api_key_id Int?

  route String? @db.VarChar(255)
  method String? @db.VarChar(10)

  status_code Int?

  request_data Json?
  response_data Json?

  ip_address String? @db.VarChar(100)

  response_time Int?

  created_at DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
}

model RefreshToken {

  id Int @id @default(autoincrement())

  user_id Int

  token String @db.Text

  expires_at DateTime

  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model DashboardAnalytics {

  id Int @id @default(autoincrement())

  user_id Int

  type String

  session_id String? @db.VarChar(255)
  visitor_id String? @db.VarChar(255)

  path String? @db.VarChar(500)
  referrer String? @db.VarChar(500)
  source String? @db.VarChar(100)
  country String? @db.VarChar(100)
  device_type String? @db.VarChar(50)
  browser String? @db.VarChar(100)
  os String? @db.VarChar(100)

  project_id Int?
  project_slug String? @db.VarChar(255)

  user_agent String? @db.VarChar(500)
  ip_address String? @db.VarChar(100)

  metadata Json?

  created_at DateTime @default(now())

  user User @relation( fields: [user_id], references: [id], onDelete: Cascade )

  @@index([user_id, created_at])
  @@index([user_id, type])
  @@index([user_id, country])
}

model VisitorSession {

  id Int @id @default(autoincrement())

  user_id Int

  visitor_id String @db.VarChar(255)
  session_id String? @db.VarChar(255)

  source String? @db.VarChar(100)
  country String? @db.VarChar(100)
  device_type String? @db.VarChar(50)
  browser String? @db.VarChar(100)
  os String? @db.VarChar(100)

  first_seen DateTime @default(now())
  last_seen DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, visitor_id])
  @@index([user_id, country])
  @@index([user_id, last_seen])
}
